# Supabase project used only for hosting this site's images
# (project: Mockup_DB, org: Onzio Mockups).
NEXT_PUBLIC_SUPABASE_URL=https://ydvggllbrswfchgjhjhr.supabase.co

# Image Transformations are a Supabase Pro-only feature. Mockup_DB is on
# the Free plan, so leave this unset/false — the loader falls back to
# serving original, unresized images either way, so nothing breaks with
# this off.
NEXT_PUBLIC_SUPABASE_IMAGE_TRANSFORMATIONS=false
